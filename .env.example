# =============================================================================
# postal-api — environment variables
#
# 1. Auto-generated by Coolify (don't set manually):
#       SERVICE_PASSWORD_POSTALAPIDB        application DB password
#       SERVICE_PASSWORD_POSTALAPIDBROOT    MariaDB root password
#
# 2. Set manually in Coolify UI:
# =============================================================================

# Coolify magic FQDN — hyphen in ID portion (per Coolify docs: identifiers with
# underscores can't use port suffix). The _8080 suffix tells Coolify to add a
# port-pinned Traefik label so routing targets FrankenPHP on :8080.
SERVICE_FQDN_POSTAL-API_8080=api.clicksenders.com

# Laravel app key — generate once with `php artisan key:generate --show`
# and paste here so it stays stable across redeploys.
APP_KEY=

# (Optional) Cross-stack: credentials for reading Postal's DB on the shared
# `postal` Docker network. Create the user in Postal's MariaDB first:
#   GRANT SELECT ON `postal`.* TO 'reader'@'%' IDENTIFIED BY '...';
#   GRANT SELECT ON `postal-server-%`.* TO 'reader'@'%';
POSTAL_DB_USERNAME=
POSTAL_DB_PASSWORD=
